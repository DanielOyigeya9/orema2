function router() {
  const hash   = window.location.hash.slice(1) || '/home';
  const [path, qs] = hash.split('?');
  const params = new URLSearchParams(qs || '');
  document.querySelectorAll('.page-section').forEach(s => s.classList.remove('active'));
  const map = {
    '/home':     () => { show('homePage');          loadHome(); },
    '/':         () => { show('homePage');          loadHome(); },
    '/listings': () => { show('listingsPage');      loadListings(params); },
    '/listing':  () => { show('listingDetailPage'); loadDetail(params.get('id')); },
    '/services': () => { show('servicesPage');      loadServices(); },
    '/contact':  () => { show('contactPage');       loadContact(); },
    '/admin':    () => { show('adminPage');         loadAdmin(); },
  };
  (map[path] || map['/'])();
  window.scrollTo(0, 0);
}
function show(id) { document.getElementById(id).classList.add('active'); }

function setupNav() {
  document.querySelectorAll('.nav-link').forEach(a =>
    a.addEventListener('click', () => { document.getElementById('mobileMenu').style.display = 'none'; })
