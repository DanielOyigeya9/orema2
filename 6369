// ════════════════════════════════════════════════════════════
//  HELPERS
// ════════════════════════════════════════════════════════════
function showLoading(v) { document.getElementById('loadingOverlay').style.display = v ? 'flex' : 'none'; }

function toast(msg, isError = false) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.className   = 'toast show' + (isError ? ' error' : '');
  setTimeout(() => t.className = 'toast', 3500);
}

function esc(s) { return (s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }

function cardHtml(l) {
  const imgs = l.listing_images || [];
  const img  = imgs.length ? imgs[0].image_url : 'https://via.placeholder.com/400x220/e2e5ea/9aa3b0?text=No+Image';
  const isLog = l.category === 'logistics';
  const bdgCls = l.status === 'sold' ? 'sold' : (isLog ? 'logistics' : '');
  const bdgTxt = l.status === 'sold' ? 'SOLD' : l.category.toUpperCase();
  const price  = isLog
    ? `<div class="lc-price" style="font-size:14px;color:var(--blue);font-weight:600">Get a Quote →</div>`
    : `<div class="lc-price">₦${Number(l.price).toLocaleString()}</div>`;
  return `<div class="listing-card" onclick="window.location.href='#/listing?id=${l.id}'">
    <img src="${esc(img)}" alt="${esc(l.title)}" loading="lazy">
    <div class="listing-card-body">
      <span class="lc-badge ${bdgCls}">${bdgTxt}</span>
      <div class="lc-title">${esc(l.title)}</div>
      ${price}
      <div class="lc-loc">📍 ${esc(l.location)}</div>
    </div>
  </div>`;
}

