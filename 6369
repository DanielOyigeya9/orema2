// ════════════════════════════════════════════════════════════
//  LISTINGS
// ════════════════════════════════════════════════════════════
function loadListings(params) {
  listFilters.category = params.get('category') || '';
  listFilters.minPrice = params.get('min')      || '';
  listFilters.maxPrice = params.get('max')      || '';
  listFilters.location = params.get('location') || '';
  listFilters.status   = params.get('status')   || 'available';
  listPage = parseInt(params.get('page')) || 1;
  renderFilters();
  fetchListings();
}

function renderFilters() {
  document.getElementById('listingFilters').innerHTML = `
    <div class="filter-wrap">
      <select id="fCat">
        <option value="">All Categories</option>
        <option value="land">Land</option>
        <option value="house">Houses</option>
        <option value="estate">Estates</option>
        <option value="car">Vehicles</option>
        <option value="logistics">Logistics</option>
      </select>
      <input type="number" id="fMin" placeholder="Min Price ₦" value="${listFilters.minPrice}">
      <input type="number" id="fMax" placeholder="Max Price ₦" value="${listFilters.maxPrice}">
      <input type="text"   id="fLoc" placeholder="Location"    value="${listFilters.location}">
      <select id="fStatus">
        <option value="available">Available</option>
        <option value="sold">Sold</option>
        <option value="">All Status</option>
      </select>
      <button class="btn-filter" onclick="applyFilters()">Apply</button>
    </div>`;
  document.getElementById('fCat').value    = listFilters.category;
  document.getElementById('fStatus').value = listFilters.status;
}

function applyFilters() {
  listFilters.category = document.getElementById('fCat').value;
  listFilters.minPrice = document.getElementById('fMin').value;
  listFilters.maxPrice = document.getElementById('fMax').value;
  listFilters.location = document.getElementById('fLoc').value;
  listFilters.status   = document.getElementById('fStatus').value;
  listPage = 1;
  fetchListings();
  const p = new URLSearchParams();
  if (listFilters.category) p.set('category', listFilters.category);
  if (listFilters.minPrice) p.set('min', listFilters.minPrice);
  if (listFilters.maxPrice) p.set('max', listFilters.maxPrice);
  if (listFilters.location) p.set('location', listFilters.location);
  if (listFilters.status !== 'available') p.set('status', listFilters.status);
  window.location.hash = '/listings?' + p.toString();
}

async function fetchListings() {
  showLoading(true);
  try {
    let query = sb.from('listings').select('*, listing_images(image_url)', {count:'exact'});
    if (listFilters.category) query = query.eq('category', listFilters.category);
    if (listFilters.status)   query = query.eq('status', listFilters.status);
    if (listFilters.minPrice) query = query.gte('price', +listFilters.minPrice);
    if (listFilters.maxPrice) query = query.lte('price', +listFilters.maxPrice);
    if (listFilters.location) query = query.ilike('location', `%${listFilters.location}%`);

    const from = (listPage - 1) * PER_PAGE;
    const to   = from + PER_PAGE - 1;
    const { data, count, error } = await query.order('created_at', {ascending:false}).range(from, to);
    if (error) throw error;

    const totalPages = Math.ceil((count||0) / PER_PAGE);

    document.getElementById('listingGrid').innerHTML = data?.length
      ? data.map(l => cardHtml(l)).join('')
      : `<div class="empty-state" style="grid-column:1/-1">No listings match your criteria.</div>`;

    const pg = document.getElementById('listingPagination');
    pg.innerHTML = '';
    for (let i = 1; i <= totalPages; i++) {
      const b = document.createElement('button');
      b.className   = 'pg-btn' + (i === listPage ? ' active' : '');
      b.textContent = i;
      b.onclick     = () => { listPage = i; fetchListings(); window.scrollTo(0,0); };
      pg.appendChild(b);
    }
  } catch(e) {
    document.getElementById('listingGrid').innerHTML = `<p class="error-banner" style="grid-column:1/-1">${e.message}</p>`;
  }
  showLoading(false);
}

// ════════════════════════════════════════════════════════════
//  DETAIL
// ════════════════════════════════════════════════════════════
async function loadDetail(id) {
  if (!id) { window.location.hash = '#/listings'; return; }
  showLoading(true);
  try {
    const { data: l, error } = await sb.from('listings').select('*, listing_images(id, image_url, sort_order)').eq('id', id).single();
    if (error) throw error;

    const imgs    = (l.listing_images || []).sort((a,b) => a.sort_order - b.sort_order);
    const det     = l.details || {};
    const detKeys = Object.keys(det);
    const mainImg = imgs[0]?.image_url || 'https://via.placeholder.com/600x380/e2e5ea/9aa3b0?text=No+Image';
    const thumbs  = imgs.map((img, i) =>
      `<img class="thumb-img${i===0?' active':''}" src="${esc(img.image_url)}" onclick="switchImg(this,'${esc(img.image_url)}')" alt="Photo">`
    ).join('');

    document.getElementById('detailContent').innerHTML = `
      <a class="back-link" onclick="history.back()">← Back to listings</a>
      <div class="grid md:grid-cols-2 gap-10">
        <div>
          <img id="mainImg" class="detail-img" src="${esc(mainImg)}" alt="${esc(l.title)}">
          <div class="thumb-row">${thumbs}</div>
        </div>
        <div>
          <div class="detail-badge">${l.category.toUpperCase()}</div>
          <div class="detail-title">${esc(l.title)}</div>
          <div class="detail-price">${l.category==='logistics'
            ? '<span style="font-size:16px;font-weight:600;color:var(--blue)">Contact us for pricing</span>'
            : `₦${Number(l.price).toLocaleString()} <em>NGN</em>`}
          </div>
          <div class="detail-loc">📍 ${esc(l.location)}</div>
          <div class="detail-desc">${esc(l.description||'')}</div>
          ${detKeys.length ? `
            <div class="specs-wrap">
              ${detKeys.map(k=>`<div class="specs-row"><div class="specs-key">${esc(k)}</div><div class="specs-val">${esc(String(det[k]))}</div></div>`).join('')}
            </div>` : ''}
          <div class="inq-box">
            <div class="inq-title">Send an Enquiry</div>
            <input class="f-input" id="iName"  placeholder="Full name">
            <input class="f-input" id="iEmail" placeholder="Email address">
            <input class="f-input" id="iPhone" placeholder="Phone number">
            <textarea class="f-input" id="iMsg" placeholder="Your message"></textarea>
            <button class="btn-submit" id="inqBtn" onclick="submitInquiry('${l.id}')">Send Enquiry</button>
            <div id="inqOk"  style="display:none" class="success-banner">✓ Enquiry received. We'll be in touch shortly.</div>
            <div id="inqErr" style="display:none" class="error-banner"></div>
          </div>
        </div>
      </div>`;
  } catch(e) {
    document.getElementById('detailContent').innerHTML = `<p class="error-banner">${e.message}</p>`;
  }
  showLoading(false);
}

function switchImg(el, src) {
  document.getElementById('mainImg').src = src;
  document.querySelectorAll('.thumb-img').forEach(t => t.classList.remove('active'));
  el.classList.add('active');
}

async function submitInquiry(listingId) {
  const name  = document.getElementById('iName').value.trim();
  const email = document.getElementById('iEmail').value.trim();
  const phone = document.getElementById('iPhone').value.trim();
  const msg   = document.getElementById('iMsg').value.trim();
  const btn   = document.getElementById('inqBtn');
  document.getElementById('inqOk').style.display  = 'none';
  document.getElementById('inqErr').style.display = 'none';
  if (!name || !email || !msg) {
    document.getElementById('inqErr').textContent  = 'Please fill in name, email and message.';
    document.getElementById('inqErr').style.display = 'block'; return;
  }
  btn.disabled = true; btn.textContent = 'Sending…';
  const { error } = await sb.from('inquiries').insert({ listing_id: listingId, name, email, phone, message: msg });
  btn.disabled = false; btn.textContent = 'Send Enquiry';
  if (error) {
    document.getElementById('inqErr').textContent  = error.message;
    document.getElementById('inqErr').style.display = 'block';
  } else {
    ['iName','iEmail','iPhone','iMsg'].forEach(id => document.getElementById(id).value = '');
    document.getElementById('inqOk').style.display = 'block';
  }
}

