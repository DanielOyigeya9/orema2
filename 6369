<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Orema Global – Real Estate, Auto & Logistics</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet">
  <style>
    :root {
      --navy:#0d1b2a; --navy-mid:#1a2f45; --blue:#1d6fa4; --blue-bright:#2589c8;
      --accent:#e8a020; --green:#1a7a4a; --green-pale:#edf7f2;
      --red-pale:#fdf0f0; --red-text:#b91c1c;
      --white:#fff; --off:#f5f6f8; --border:#e2e5ea;
      --text:#0d1b2a; --muted:#6b7584; --light:#9aa3b0;
    }
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    body{font-family:'Sora',sans-serif;background:var(--off);color:var(--text);font-size:15px;line-height:1.6;-webkit-font-smoothing:antialiased}

    .topbar{background:var(--navy);padding:8px 0;font-size:12px;color:rgba(255,255,255,.5)}
    .topbar-inner{max-width:1200px;margin:0 auto;padding:0 28px;display:flex;justify-content:space-between;align-items:center}
    .topbar a{color:rgba(255,255,255,.55);text-decoration:none}.topbar a:hover{color:#fff}
    @media(max-width:768px){.topbar{display:none}}

    .nav-bar{background:var(--white);border-bottom:1px solid var(--border);position:sticky;top:0;z-index:100}
    .nav-inner{max-width:1200px;margin:0 auto;padding:0 28px;display:flex;align-items:center;justify-content:space-between;height:64px}
    .nav-logo{font-size:18px;font-weight:700;color:var(--navy);letter-spacing:-.5px;text-decoration:none}
    .nav-logo em{font-style:normal;color:var(--blue)}
    .nav-logo span{font-family:'IBM Plex Mono',monospace;font-size:10px;font-weight:400;color:var(--light);display:block;letter-spacing:1.5px;margin-top:-2px}
    .nav-links{display:flex;align-items:center;gap:4px}
    .nav-links a{font-size:13.5px;font-weight:500;color:var(--muted);text-decoration:none;padding:6px 14px;border-radius:6px;transition:color .15s,background .15s}
    .nav-links a:hover{color:var(--navy);background:var(--off)}
    .nav-links a.cta{background:var(--navy);color:#fff;padding:7px 18px;margin-left:8px}
    .nav-links a.cta:hover{background:var(--navy-mid);color:#fff}
    .hamburger{display:none;background:none;border:none;cursor:pointer;padding:6px;color:var(--navy)}
    .mobile-nav{display:none;background:var(--white);border-top:1px solid var(--border);padding:12px 20px 20px}
    .mobile-nav a{display:block;padding:11px 4px;font-size:14px;color:var(--text);text-decoration:none;border-bottom:1px solid var(--border)}
    .mobile-nav a:last-child{border:none}
    @media(max-width:768px){.nav-links{display:none}.hamburger{display:block}}

    .page-section{display:none}.page-section.active{display:block}
    .wrap{max-width:1200px;margin:0 auto;padding:0 28px}
    .page-pad{padding-top:40px;padding-bottom:80px}
    @media(max-width:768px){.wrap{padding:0 16px}}

    /* HERO */
    .hero-outer{background:var(--navy);position:relative;overflow:hidden}
    .hero-grid-bg{position:absolute;inset:0;pointer-events:none;background-image:linear-gradient(rgba(255,255,255,.03) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,.03) 1px,transparent 1px);background-size:48px 48px}
    .hero-stripe{position:absolute;right:0;top:0;bottom:0;width:38%;background:var(--navy-mid);clip-path:polygon(12% 0,100% 0,100% 100%,0% 100%)}
    @media(max-width:768px){.hero-stripe{display:none}}
    .hero-inner{position:relative;z-index:2;max-width:1200px;margin:0 auto;padding:80px 28px 72px}
    .hero-tag{display:inline-flex;align-items:center;gap:8px;font-family:'IBM Plex Mono',monospace;font-size:11px;color:var(--accent);letter-spacing:2px;text-transform:uppercase;margin-bottom:20px}
    .hero-tag::before{content:'';display:block;width:20px;height:1.5px;background:var(--accent)}
    .hero h1{font-size:clamp(30px,4.5vw,52px);font-weight:700;color:#fff;line-height:1.12;letter-spacing:-1px;max-width:560px;margin-bottom:20px}
    .hero h1 em{font-style:normal;color:var(--blue-bright)}
    .hero-sub{font-size:15px;color:rgba(255,255,255,.55);max-width:480px;line-height:1.75;margin-bottom:36px;font-weight:300}
    .hero-btns{display:flex;gap:12px;flex-wrap:wrap}
    .btn-hero-primary{background:var(--blue);color:#fff;padding:13px 28px;border-radius:6px;font-size:14px;font-weight:600;text-decoration:none;transition:background .2s;display:inline-block;border:none;cursor:pointer;font-family:'Sora',sans-serif}
    .btn-hero-primary:hover{background:var(--blue-bright)}
    .btn-hero-ghost{background:transparent;color:rgba(255,255,255,.75);border:1px solid rgba(255,255,255,.2);padding:13px 28px;border-radius:6px;font-size:14px;font-weight:500;text-decoration:none;transition:all .2s;display:inline-block;cursor:pointer;font-family:'Sora',sans-serif}
    .btn-hero-ghost:hover{border-color:rgba(255,255,255,.5);color:#fff}

    /* STATS */
    .stats-band{background:var(--white);border-bottom:1px solid var(--border)}
    .stats-band-inner{max-width:1200px;margin:0 auto;padding:0 28px;display:grid;grid-template-columns:repeat(4,1fr);border-left:1px solid var(--border)}
    @media(max-width:768px){.stats-band-inner{grid-template-columns:repeat(2,1fr)}}
    .stat-cell{padding:28px 24px;border-right:1px solid var(--border);border-bottom:1px solid var(--border)}
    .stat-n{font-size:30px;font-weight:700;color:var(--navy);letter-spacing:-1px;line-height:1}
    .stat-n em{font-style:normal;color:var(--blue)}
    .stat-l{font-size:12px;color:var(--muted);margin-top:4px}

    .sec-label{font-family:'IBM Plex Mono',monospace;font-size:11px;color:var(--blue);letter-spacing:2px;text-transform:uppercase;margin-bottom:10px}
    .sec-title{font-size:24px;font-weight:700;color:var(--navy);letter-spacing:-.5px;margin-bottom:28px}

    /* CARDS */
    .listing-card{background:var(--white);border:1px solid var(--border);border-radius:10px;overflow:hidden;cursor:pointer;transition:box-shadow .2s,border-color .2s;display:flex;flex-direction:column}
    .listing-card:hover{border-color:#b0bec8;box-shadow:0 4px 24px rgba(13,27,42,.08)}
    .listing-card img{width:100%;height:200px;object-fit:cover;display:block;background:var(--off)}
    .listing-card-body{padding:16px 18px 20px;flex:1;display:flex;flex-direction:column}
    .lc-badge{font-family:'IBM Plex Mono',monospace;font-size:10px;letter-spacing:1px;text-transform:uppercase;padding:3px 8px;border-radius:3px;background:#eef4fb;color:var(--blue);font-weight:500;margin-bottom:8px;display:inline-block}
    .lc-badge.sold{background:var(--red-pale);color:var(--red-text)}
    .lc-badge.logistics{background:#fff4e6;color:#b45309}
    .lc-title{font-size:15px;font-weight:600;color:var(--navy);margin-bottom:6px;line-height:1.35}
    .lc-price{font-size:17px;font-weight:700;color:var(--navy);margin-bottom:4px}
    .lc-loc{font-size:12px;color:var(--muted);margin-top:auto;padding-top:8px}

    /* SERVICES */
    .svc-card{background:var(--white);border:1px solid var(--border);border-radius:10px;padding:24px}
    .svc-icon-wrap{width:44px;height:44px;border-radius:8px;background:#eef4fb;display:flex;align-items:center;justify-content:center;font-size:22px;margin-bottom:14px}
    .svc-title{font-size:15px;font-weight:600;color:var(--navy);margin-bottom:6px}
    .svc-desc{font-size:13px;color:var(--muted);line-height:1.65}
    .svc-content{font-size:12.5px;color:var(--light);margin-top:12px;border-top:1px solid var(--border);padding-top:12px;line-height:1.6}

    /* FILTERS */
    .filter-wrap{background:var(--white);border:1px solid var(--border);border-radius:10px;padding:16px 20px;margin-bottom:24px;display:flex;flex-wrap:wrap;align-items:center;gap:10px}
    .filter-wrap select,.filter-wrap input{border:1px solid var(--border);border-radius:6px;padding:9px 13px;font-size:13px;font-family:'Sora',sans-serif;color:var(--text);background:var(--off);outline:none;transition:border-color .15s}
    .filter-wrap select:focus,.filter-wrap input:focus{border-color:var(--blue)}
    .filter-wrap input[type=number]{width:116px}.filter-wrap input[type=text]{width:140px}
    .btn-filter{background:var(--navy);color:#fff;border:none;border-radius:6px;padding:9px 20px;font-size:13px;font-weight:600;font-family:'Sora',sans-serif;cursor:pointer}
    .btn-filter:hover{background:var(--navy-mid)}

    .pg{display:flex;justify-content:center;gap:6px;margin-top:36px}
    .pg-btn{width:36px;height:36px;border-radius:6px;border:1px solid var(--border);background:var(--white);font-size:13px;font-weight:500;cursor:pointer;font-family:'Sora',sans-serif;color:var(--muted);transition:all .15s}
    .pg-btn:hover{border-color:var(--blue);color:var(--blue)}
    .pg-btn.active{background:var(--navy);color:#fff;border-color:var(--navy)}

    /* DETAIL */
    .back-link{display:inline-flex;align-items:center;gap:6px;font-size:13px;font-weight:500;color:var(--blue);cursor:pointer;margin-bottom:24px;text-decoration:none}
    .back-link:hover{text-decoration:underline}
    .detail-img{width:100%;height:380px;object-fit:cover;border-radius:10px;background:var(--off)}
    .thumb-row{display:flex;gap:8px;margin-top:8px;flex-wrap:wrap}
    .thumb-img{width:66px;height:66px;object-fit:cover;border-radius:6px;cursor:pointer;border:2px solid transparent;transition:border-color .15s;background:var(--off)}
    .thumb-img.active{border-color:var(--blue)}
    .detail-badge{display:inline-block;font-family:'IBM Plex Mono',monospace;font-size:10px;letter-spacing:1.5px;text-transform:uppercase;background:#eef4fb;color:var(--blue);padding:4px 10px;border-radius:3px;margin-bottom:12px}
    .detail-title{font-size:28px;font-weight:700;color:var(--navy);letter-spacing:-.5px;margin-bottom:6px;line-height:1.2}
    .detail-price{font-size:24px;font-weight:700;color:var(--navy);margin-bottom:4px}
    .detail-price em{font-style:normal;font-size:14px;color:var(--muted);font-weight:400}
    .detail-loc{font-size:13px;color:var(--muted);margin-bottom:20px}
    .detail-desc{font-size:14px;color:#444;line-height:1.8;margin-bottom:20px}
    .specs-wrap{border:1px solid var(--border);border-radius:8px;overflow:hidden;margin-bottom:24px}
    .specs-row{display:flex;border-bottom:1px solid var(--border);font-size:13px}
    .specs-row:last-child{border-bottom:none}
    .specs-key{padding:10px 14px;color:var(--muted);width:44%;background:var(--off);font-weight:500}
    .specs-val{padding:10px 14px;color:var(--text)}
    .inq-box{background:var(--off);border:1px solid var(--border);border-radius:10px;padding:22px}
    .inq-title{font-size:14px;font-weight:600;color:var(--navy);margin-bottom:14px}

    /* FORMS */
    .f-input{width:100%;border:1px solid var(--border);border-radius:6px;padding:10px 14px;font-size:13.5px;font-family:'Sora',sans-serif;color:var(--text);background:var(--white);outline:none;margin-bottom:10px;transition:border-color .15s}
    .f-input:focus{border-color:var(--blue)}
    textarea.f-input{resize:vertical;min-height:96px}
    .btn-submit{background:var(--blue);color:#fff;border:none;border-radius:6px;padding:11px 24px;font-size:13.5px;font-weight:600;font-family:'Sora',sans-serif;cursor:pointer;transition:background .15s}
    .btn-submit:hover{background:var(--blue-bright)}
    .btn-submit:disabled{opacity:.6;cursor:not-allowed}
    .form-card{background:var(--white);border:1px solid var(--border);border-radius:10px;padding:28px}

    /* CONTACT */
    .contact-info-card{background:var(--navy);border-radius:10px;padding:32px;color:rgba(255,255,255,.75)}
    .contact-info-card h3{font-size:17px;font-weight:600;color:#fff;margin-bottom:20px}
    .contact-row{display:flex;gap:12px;margin-bottom:18px;align-items:flex-start}
    .contact-icon{width:34px;height:34px;border-radius:6px;background:rgba(255,255,255,.08);display:flex;align-items:center;justify-content:center;font-size:16px;flex-shrink:0}
    .contact-lbl{font-size:11px;color:rgba(255,255,255,.4);letter-spacing:.5px;margin-bottom:2px}
    .contact-val{font-size:13.5px;color:rgba(255,255,255,.85)}
    .map-box{background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.1);border-radius:8px;height:160px;display:flex;align-items:center;justify-content:center;font-size:13px;color:rgba(255,255,255,.3);margin-top:24px;font-family:'IBM Plex Mono',monospace}

    .page-title-bar{border-bottom:1px solid var(--border);background:var(--white);padding:24px 0;margin-bottom:28px}
    .page-title-bar h1{font-size:22px;font-weight:700;color:var(--navy);letter-spacing:-.3px}

    /* ADMIN */
    .admin-login-wrap{max-width:400px;margin:60px auto;background:var(--white);border:1px solid var(--border);border-radius:10px;padding:36px 32px}
    .admin-login-title{font-size:20px;font-weight:700;color:var(--navy);margin-bottom:6px}
    .admin-login-sub{font-size:13px;color:var(--muted);margin-bottom:24px}
    .admin-sidebar{width:220px;flex-shrink:0;background:var(--white);border:1px solid var(--border);border-radius:10px;padding:16px 0;height:fit-content}
    .admin-sidebar-label{font-family:'IBM Plex Mono',monospace;font-size:10px;letter-spacing:2px;color:var(--light);text-transform:uppercase;padding:0 18px 12px}
    .admin-nav-btn{display:flex;align-items:center;gap:10px;width:100%;padding:10px 18px;background:none;border:none;font-size:13.5px;font-family:'Sora',sans-serif;color:var(--muted);text-align:left;cursor:pointer;transition:background .15s,color .15s}
    .admin-nav-btn:hover{background:var(--off);color:var(--navy)}
    .admin-nav-btn.danger:hover{background:#fdf0f0;color:var(--red-text)}
    .admin-content{flex:1;background:var(--white);border:1px solid var(--border);border-radius:10px;padding:28px;min-width:0}
    .admin-content-title{font-size:18px;font-weight:700;color:var(--navy);letter-spacing:-.3px;margin-bottom:20px}
    .kpi-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;margin-bottom:28px}
    @media(max-width:600px){.kpi-grid{grid-template-columns:1fr 1fr}}
    .kpi-card{background:var(--off);border:1px solid var(--border);border-radius:8px;padding:18px}
    .kpi-n{font-size:28px;font-weight:700;color:var(--navy);letter-spacing:-1px}
    .kpi-l{font-size:12px;color:var(--muted);margin-top:2px}
    .btn-add{background:var(--navy);color:#fff;border:none;border-radius:6px;padding:9px 18px;font-size:13px;font-weight:600;font-family:'Sora',sans-serif;cursor:pointer;margin-bottom:18px;transition:background .15s;display:inline-flex;align-items:center;gap:6px}
    .btn-add:hover{background:var(--navy-mid)}
    .a-table{width:100%;border-collapse:collapse;font-size:13px}
    .a-table thead th{text-align:left;padding:9px 12px;font-size:11px;font-weight:600;color:var(--light);letter-spacing:.5px;text-transform:uppercase;border-bottom:1px solid var(--border);background:var(--off)}
    .a-table tbody td{padding:12px;border-bottom:1px solid var(--border);color:var(--text)}
    .a-table tbody tr:last-child td{border-bottom:none}
    .a-table tbody tr:hover td{background:#fafbfc}
    .tbl-btn{background:none;border:none;font-size:12.5px;font-family:'Sora',sans-serif;cursor:pointer;font-weight:500;padding:2px 0}
    .tbl-edit{color:var(--blue)}.tbl-del{color:var(--red-text);margin-left:10px}
    .tbl-edit:hover,.tbl-del:hover{text-decoration:underline}
    .status-pill{display:inline-block;font-size:11px;font-weight:600;padding:2px 9px;border-radius:20px;font-family:'IBM Plex Mono',monospace}
    .status-avail{background:var(--green-pale);color:var(--green)}
    .status-sold{background:var(--red-pale);color:var(--red-text)}
    .inq-item{border:1px solid var(--border);border-radius:8px;padding:16px;margin-bottom:10px;background:var(--off)}
    .inq-item.unread{border-left:3px solid var(--blue)}
    .inq-name{font-size:14px;font-weight:600;color:var(--navy)}
    .inq-meta{font-size:12px;color:var(--muted);margin:3px 0 8px}
    .inq-msg{font-size:13px;color:var(--text);line-height:1.6}

    /* MODAL */
    .modal-bg{position:fixed;inset:0;background:rgba(13,27,42,.55);display:flex;align-items:flex-start;justify-content:center;z-index:200;padding:20px;overflow-y:auto}
    .modal-box{background:var(--white);border-radius:12px;padding:28px;max-width:640px;width:100%;margin:auto}
    .modal-title{font-size:17px;font-weight:700;color:var(--navy);margin-bottom:20px}
    .modal-section-label{font-family:'IBM Plex Mono',monospace;font-size:10px;letter-spacing:1.5px;color:var(--light);text-transform:uppercase;margin-bottom:8px;margin-top:16px}
    .m-input{width:100%;border:1px solid var(--border);border-radius:6px;padding:10px 14px;font-size:13.5px;font-family:'Sora',sans-serif;color:var(--text);background:var(--off);outline:none;margin-bottom:10px;transition:border-color .15s}
    .m-input:focus{border-color:var(--blue);background:var(--white)}
    .m-check-label{display:flex;align-items:center;gap:8px;font-size:13px;color:var(--muted);cursor:pointer;margin-bottom:16px}
    .modal-footer{display:flex;justify-content:flex-end;gap:10px;margin-top:20px}
    .btn-cancel{border:1px solid var(--border);background:var(--white);border-radius:6px;padding:9px 20px;font-size:13px;cursor:pointer;font-family:'Sora',sans-serif;color:var(--muted)}
    .btn-cancel:hover{background:var(--off)}
    .btn-save{background:var(--navy);color:#fff;border:none;border-radius:6px;padding:9px 22px;font-size:13px;font-weight:600;font-family:'Sora',sans-serif;cursor:pointer}
    .btn-save:hover{background:var(--navy-mid)}
    .btn-save:disabled{opacity:.6;cursor:not-allowed}

    /* PHOTO UPLOAD */
    .photo-grid{display:flex;flex-wrap:wrap;gap:8px;margin:10px 0}
    .photo-item{position:relative;width:80px;height:80px}
    .photo-item img{width:100%;height:100%;object-fit:cover;border-radius:6px;border:1px solid var(--border)}
    .photo-rm{position:absolute;top:3px;right:3px;width:18px;height:18px;border-radius:50%;background:rgba(185,28,28,.85);color:#fff;border:none;cursor:pointer;font-size:11px;display:flex;align-items:center;justify-content:center}
    .upload-area{border:2px dashed var(--border);border-radius:8px;padding:16px;text-align:center;cursor:pointer;transition:border-color .15s;margin-top:8px}
    .upload-area:hover{border-color:var(--blue)}
    .upload-area input{display:none}
    .upload-area-label{font-size:13px;color:var(--muted)}
    .upload-progress{font-size:12px;color:var(--blue);margin-top:6px;font-family:'IBM Plex Mono',monospace}

    /* LOADING & ALERTS */
    .loading-overlay{position:fixed;inset:0;background:rgba(255,255,255,.85);display:flex;align-items:center;justify-content:center;z-index:300}
    .spinner{width:36px;height:36px;border-radius:50%;border:3px solid var(--border);border-top-color:var(--blue);animation:spin .75s linear infinite}
    @keyframes spin{to{transform:rotate(360deg)}}
    .success-banner{font-size:13px;color:var(--green);font-weight:500;margin-top:10px;padding:10px 14px;background:var(--green-pale);border-radius:6px}
    .error-banner{font-size:13px;color:var(--red-text);font-weight:500;margin-top:10px;padding:10px 14px;background:var(--red-pale);border-radius:6px}
    .toast{position:fixed;bottom:24px;right:24px;background:var(--navy);color:#fff;padding:12px 20px;border-radius:8px;font-size:13px;font-weight:500;z-index:400;transform:translateY(80px);opacity:0;transition:all .3s;max-width:300px}
    .toast.show{transform:translateY(0);opacity:1}
    .toast.error{background:var(--red-text)}
    .empty-state{text-align:center;padding:60px 0;color:var(--muted);font-size:14px}
  </style>
</head>
<body>

<div class="topbar">
  <div class="topbar-inner">
    <span>📍 15 Orema Street, Lekki, Lagos, Nigeria</span>
    <span><a href="tel:+2348000000000">+234 800 000 0000</a> &nbsp;·&nbsp; <a href="mailto:info@oremaglobal.com">info@oremaglobal.com</a></span>
  </div>
</div>

<nav class="nav-bar">
  <div class="nav-inner">
    <a href="#/home" class="nav-logo">Orema <em>Global</em><span>REAL ESTATE · AUTO · LOGISTICS</span></a>
    <div class="nav-links">
      <a href="#/home"     class="nav-link">Home</a>
      <a href="#/listings" class="nav-link">Listings</a>
      <a href="#/services" class="nav-link">Services</a>
      <a href="#/contact"  class="nav-link">Contact</a>
      <a href="#/admin"    class="nav-link cta">Admin</a>
    </div>
