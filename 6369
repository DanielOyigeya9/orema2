  const [
    { count: propCount },
    { count: carCount },
    { count: inqCount }
  ] = await Promise.all([
    sb.from('listings').select('*',{count:'exact',head:true}).in('category',['land','house','estate']),
    sb.from('listings').select('*',{count:'exact',head:true}).eq('category','car'),
    sb.from('inquiries').select('*',{count:'exact',head:true}),
  ]);
  showLoading(false);

  document.getElementById('adminContainer').innerHTML = `
    <div class="admin-sidebar">
      <div class="admin-sidebar-label">Navigation</div>
      <button class="admin-nav-btn" onclick="adminSection('listings')">📋 &nbsp;Listings</button>
      <button class="admin-nav-btn" onclick="adminSection('inquiries')">📩 &nbsp;Inquiries</button>
      <button class="admin-nav-btn danger" onclick="adminLogout()">🚪 &nbsp;Logout</button>
    </div>
    <div class="admin-content" id="adminContent">
      <div class="kpi-grid">
        <div class="kpi-card"><div class="kpi-n">${propCount||0}</div><div class="kpi-l">Properties</div></div>
        <div class="kpi-card"><div class="kpi-n">${carCount||0}</div><div class="kpi-l">Vehicles</div></div>
        <div class="kpi-card"><div class="kpi-n">${inqCount||0}</div><div class="kpi-l">Inquiries</div></div>
      </div>
      <p style="color:var(--muted);font-size:13px">Select a section from the sidebar.</p>
    </div>`;
  adminSection('listings');
}

// ════════════════════════════════════════════════════════════
//  ADMIN — SECTIONS
// ════════════════════════════════════════════════════════════
async function adminSection(sec) {
  const area = document.getElementById('adminContent');
  if (!area) return;
  showLoading(true);

  if (sec === 'listings') {
    const { data, error } = await sb.from('listings').select('*, listing_images(image_url)').order('created_at', {ascending:false});
    showLoading(false);
    if (error) { area.innerHTML = `<p class="error-banner">${error.message}</p>`; return; }
    area.innerHTML = `
      <div class="admin-content-title">All Listings</div>
      <button class="btn-add" onclick="openListingForm()">+ Add Listing</button>
      <div style="overflow-x:auto">
        <table class="a-table">
          <thead><tr><th>Title</th><th>Category</th><th>Price</th><th>Status</th><th>Featured</th><th>Actions</th></tr></thead>
          <tbody>${(data||[]).map(l => `<tr>
            <td style="font-weight:500;max-width:200px">${esc(l.title)}</td>
            <td style="color:var(--muted)">${l.category}</td>
            <td>${l.category==='logistics' ? '—' : '₦'+Number(l.price).toLocaleString()}</td>
            <td><span class="status-pill ${l.status==='available'?'status-avail':'status-sold'}">${l.status}</span></td>
            <td>${l.is_featured ? '⭐' : '—'}</td>
            <td>
              <button class="tbl-btn tbl-edit" onclick="editListing('${l.id}')">Edit</button>
              <button class="tbl-btn tbl-del"  onclick="deleteListing('${l.id}','${esc(l.title)}')">Delete</button>
            </td>
          </tr>`).join('')}</tbody>
        </table>
      </div>`;
  }

  if (sec === 'inquiries') {
    const { data, error } = await sb.from('inquiries')
      .select('*, listings(title)')
      .order('created_at', {ascending:false});
    showLoading(false);
    if (error) { area.innerHTML = `<p class="error-banner">${error.message}</p>`; return; }
    area.innerHTML = `
      <div class="admin-content-title">Inquiries (${data?.length||0})</div>
      ${(data||[]).length ? (data||[]).map(i => `
        <div class="inq-item">
          <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:10px">
            <div>
              <div class="inq-name">${esc(i.name)}</div>
              <div class="inq-meta">
                ${esc(i.email)}${i.phone ? ' · '+esc(i.phone) : ''}
                ${i.listings?.title ? ' · Re: '+esc(i.listings.title) : ''}
                · ${new Date(i.created_at).toLocaleDateString('en-NG')}
              </div>
            </div>
            <button class="tbl-btn tbl-del" onclick="deleteInquiry('${i.id}',this)">Delete</button>
          </div>
          <div class="inq-msg">${esc(i.message)}</div>
        </div>`).join('')
        : '<p class="empty-state">No inquiries yet.</p>'}`;
  }
}

async function deleteInquiry(id, btn) {
  if (!confirm('Delete this inquiry?')) return;
  const { error } = await sb.from('inquiries').delete().eq('id', id);
  if (error) { toast(error.message, true); return; }
  btn.closest('.inq-item').remove();
  toast('Inquiry deleted');
}

// ════════════════════════════════════════════════════════════
//  LISTING FORM
// ════════════════════════════════════════════════════════════
let editingId      = null;
let existingImages = []; // [{id, image_url}]

function openListingForm(listing = null) {
  editingId      = listing?.id || null;
  existingImages = (listing?.listing_images || []).sort((a,b)=>a.sort_order-b.sort_order);
  const isEdit   = !!listing;
  const d        = listing?.details || {};

  const overlay = document.createElement('div');
  overlay.className = 'modal-bg'; overlay.id = 'lModal';
  overlay.innerHTML = `
    <div class="modal-box">
      <div class="modal-title">${isEdit ? 'Edit Listing' : 'New Listing'}</div>

      <div class="modal-section-label">Basic Info</div>
      <input  class="m-input" id="lTitle" placeholder="Listing title" value="${esc(listing?.title||'')}">
      <select class="m-input" id="lCat" onchange="toggleDetFields()" style="margin-bottom:10px">
        <option value="land"      ${listing?.category==='land'      ?'selected':''}>Land</option>
        <option value="house"     ${listing?.category==='house'     ?'selected':''}>House</option>
        <option value="estate"    ${listing?.category==='estate'    ?'selected':''}>Estate</option>
        <option value="car"       ${listing?.category==='car'       ?'selected':''}>Vehicle</option>
        <option value="logistics" ${listing?.category==='logistics' ?'selected':''}>Logistics</option>
      </select>
      <textarea class="m-input" id="lDesc" placeholder="Description" rows="3">${esc(listing?.description||'')}</textarea>
      <input class="m-input" id="lPrice" type="number" placeholder="Price in ₦ (0 for logistics)" value="${listing?.price||''}">
      <input class="m-input" id="lLoc"   placeholder="Location" value="${esc(listing?.location||'')}">
      <select class="m-input" id="lStatus" style="margin-bottom:10px">
        <option value="available" ${listing?.status==='available'||!listing?'selected':''}>Available</option>
        <option value="sold"      ${listing?.status==='sold'           ?'selected':''}>Sold</option>
      </select>
      <label class="m-check-label">
        <input type="checkbox" id="lFeat" ${listing?.is_featured?'checked':''}> Feature on homepage
      </label>

      <div id="detFields"></div>

      <div class="modal-section-label">Photos (max 5)</div>
      <div class="photo-grid" id="photoGrid"></div>
      <div class="upload-area" onclick="document.getElementById('photoIn').click()">
        <input type="file" id="photoIn" accept="image/jpeg,image/png,image/webp" onchange="uploadPhoto(event)">
        <div class="upload-area-label">📷 Click to upload a photo (JPG, PNG, WebP · max 5MB)</div>
        <div id="uploadProgress" class="upload-progress"></div>
      </div>

      <div class="modal-footer">
        <button class="btn-cancel" onclick="closeListingForm()">Cancel</button>
        <button class="btn-save" id="saveBtn" onclick="saveListing()">
          ${isEdit ? 'Save Changes' : 'Create Listing'}
        </button>
      </div>
    </div>`;
  document.body.appendChild(overlay);
  renderPhotoGrid();
  toggleDetFields();
  if (isEdit) setTimeout(() => fillDetFields(listing.category, d), 10);
}

function toggleDetFields() {
  const cat = document.getElementById('lCat')?.value;
  const c   = document.getElementById('detFields'); if (!c) return;
  let h = `<div class="modal-section-label">Specifications</div>`;
  if (cat==='land')      h += `<input class="m-input" id="dSize" placeholder="Size (e.g. 500 sqm)"><input class="m-input" id="dZone" placeholder="Zoning (e.g. Residential)"><input class="m-input" id="dTopo" placeholder="Topography (e.g. Flat)">`;
  if (cat==='house')     h += `<input class="m-input" id="dBed" type="number" placeholder="Bedrooms"><input class="m-input" id="dBath" type="number" placeholder="Bathrooms"><input class="m-input" id="dSqft" placeholder="Square Feet"><input class="m-input" id="dYear" placeholder="Year Built">`;
  if (cat==='estate')    h += `<input class="m-input" id="dUnits" placeholder="Total Units"><input class="m-input" id="dAmen" placeholder="Amenities (e.g. Gym, Pool)"><input class="m-input" id="dArea" placeholder="Total Area">`;
  if (cat==='car')       h += `<input class="m-input" id="dMake" placeholder="Make (e.g. Toyota)"><input class="m-input" id="dModel" placeholder="Model (e.g. Camry)"><input class="m-input" id="dCarYear" type="number" placeholder="Year"><input class="m-input" id="dMile" placeholder="Mileage (e.g. 28,000 km)"><input class="m-input" id="dCond" placeholder="Condition (e.g. Foreign Used)">`;
  if (cat==='logistics') h += `<input class="m-input" id="dSvcType" placeholder="Service Type (e.g. Haulage)"><input class="m-input" id="dCoverage" placeholder="Coverage Area"><input class="m-input" id="dCapacity" placeholder="Capacity / Fleet Size"><input class="m-input" id="dTurnaround" placeholder="Turnaround Time">`;
  c.innerHTML = h;
}

function fillDetFields(cat, d) {
  const sv = (id,v) => { const el=document.getElementById(id); if(el) el.value=v||''; };
  if (cat==='land')      { sv('dSize',d.size); sv('dZone',d.zoning); sv('dTopo',d.topography); }
  if (cat==='house')     { sv('dBed',d.bedrooms); sv('dBath',d.bathrooms); sv('dSqft',d.squareFeet); sv('dYear',d.yearBuilt); }
  if (cat==='estate')    { sv('dUnits',d.totalUnits); sv('dAmen',d.amenities); sv('dArea',d.totalArea); }
  if (cat==='car')       { sv('dMake',d.make); sv('dModel',d.model); sv('dCarYear',d.year); sv('dMile',d.mileage); sv('dCond',d.condition); }
  if (cat==='logistics') { sv('dSvcType',d.serviceType); sv('dCoverage',d.coverage); sv('dCapacity',d.capacity); sv('dTurnaround',d.turnaround); }
}

function collectDetFields(cat) {
  const gv = id => document.getElementById(id)?.value?.trim() || '';
  if (cat==='land')      return {size:gv('dSize'),zoning:gv('dZone'),topography:gv('dTopo')};
  if (cat==='house')     return {bedrooms:gv('dBed'),bathrooms:gv('dBath'),squareFeet:gv('dSqft'),yearBuilt:gv('dYear')};
  if (cat==='estate')    return {totalUnits:gv('dUnits'),amenities:gv('dAmen'),totalArea:gv('dArea')};
  if (cat==='car')       return {make:gv('dMake'),model:gv('dModel'),year:gv('dCarYear'),mileage:gv('dMile'),condition:gv('dCond')};
  if (cat==='logistics') return {serviceType:gv('dSvcType'),coverage:gv('dCoverage'),capacity:gv('dCapacity'),turnaround:gv('dTurnaround')};
  return {};
}

function renderPhotoGrid() {
  const g = document.getElementById('photoGrid'); if (!g) return;
  g.innerHTML = existingImages.map((img,i) => `
    <div class="photo-item">
      <img src="${esc(img.image_url)}" alt="Photo ${i+1}">
      <button class="photo-rm" onclick="removePhoto('${img.id}',this)" title="Remove">×</button>
    </div>`).join('');
}

async function uploadPhoto(event) {
  const file = event.target.files[0]; if (!file) return;
  if (existingImages.length >= 5) { toast('Maximum 5 photos per listing', true); event.target.value=''; return; }
  if (file.size > 5*1024*1024)    { toast('Image must be under 5MB', true); event.target.value=''; return; }

  const progress = document.getElementById('uploadProgress');
  progress.textContent = 'Uploading…';

  // If new listing, create it first so we have an ID for storage path
  if (!editingId) {
    const title = document.getElementById('lTitle').value.trim();
    const loc   = document.getElementById('lLoc').value.trim();
    if (!title || !loc) {
      toast('Please fill in Title and Location first, then upload photos', true);
      progress.textContent = ''; event.target.value=''; return;
    }
    await saveListing(true); // save without closing
    if (!editingId) { progress.textContent=''; event.target.value=''; return; }
  }

  const ext      = file.name.split('.').pop().toLowerCase();
  const filename = `${editingId}/${Date.now()}.${ext}`;

  const { error: upErr } = await sb.storage.from('listing-images').upload(filename, file, { upsert: false });
  if (upErr) { toast(upErr.message, true); progress.textContent=''; event.target.value=''; return; }

  const { data: { publicUrl } } = sb.storage.from('listing-images').getPublicUrl(filename);

  const sortOrder = existingImages.length;
  const { data: imgRow, error: dbErr } = await sb.from('listing_images')
    .insert({ listing_id: editingId, image_url: publicUrl, sort_order: sortOrder })
    .select().single();

  if (dbErr) { toast(dbErr.message, true); } else {
    existingImages.push({ id: imgRow.id, image_url: publicUrl });
    renderPhotoGrid();
    toast('Photo uploaded ✓');
  }
  progress.textContent = '';
  event.target.value   = '';
}

async function removePhoto(imgId, btn) {
  if (!confirm('Remove this photo?')) return;
  const { error } = await sb.from('listing_images').delete().eq('id', imgId);
  if (error) { toast(error.message, true); return; }
  existingImages = existingImages.filter(i => i.id != imgId);
  btn.closest('.photo-item').remove();
}

async function saveListing(keepOpen = false) {
  const title   = document.getElementById('lTitle').value.trim();
  const cat     = document.getElementById('lCat').value;
  const desc    = document.getElementById('lDesc').value.trim();
  const price   = parseFloat(document.getElementById('lPrice').value) || 0;
  const loc     = document.getElementById('lLoc').value.trim();
  const status  = document.getElementById('lStatus').value;
  const feat    = document.getElementById('lFeat').checked;
  const details = collectDetFields(cat);
  const btn     = document.getElementById('saveBtn');

  if (!title) { toast('Title is required', true); return; }
  if (!loc)   { toast('Location is required', true); return; }

  if(btn) { btn.disabled=true; btn.textContent='Saving…'; }

  const payload = { title, category:cat, description:desc, price, location:loc, status, is_featured:feat, details };

  let error;
  if (editingId) {
    ({ error } = await sb.from('listings').update(payload).eq('id', editingId));
  } else {
    const { data, error: e } = await sb.from('listings').insert(payload).select().single();
    error = e;
    if (!error) editingId = data.id;
  }

  if(btn) { btn.disabled=false; btn.textContent = editingId && !keepOpen ? 'Save Changes' : 'Create Listing'; }

  if (error) { toast(error.message, true); return; }

  if (!keepOpen) {
    toast(editingId ? 'Listing saved ✓' : 'Listing created ✓');
    closeListingForm();
    adminSection('listings');
  }
}

function closeListingForm() { document.getElementById('lModal')?.remove(); }

async function editListing(id) {
  showLoading(true);
  const { data, error } = await sb.from('listings').select('*, listing_images(id, image_url, sort_order)').eq('id', id).single();
  showLoading(false);
  if (error) { toast(error.message, true); return; }
  openListingForm(data);
}

async function deleteListing(id, title) {
  if (!confirm(`Delete "${title}" and all its photos?`)) return;
  // Delete storage files first
  const { data: imgs } = await sb.from('listing_images').select('image_url').eq('listing_id', id);
  if (imgs?.length) {
    const paths = imgs.map(i => i.image_url.split('/listing-images/')[1]).filter(Boolean);
    if (paths.length) await sb.storage.from('listing-images').remove(paths);
  }
  const { error } = await sb.from('listings').delete().eq('id', id);
  if (error) { toast(error.message, true); return; }
  toast('Listing deleted');
  adminSection('listings');
}
</script>
</body>
</html>
